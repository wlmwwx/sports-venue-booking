.tabs {
  white-space: nowrap;
  padding: 16rpx 4rpx;
  background: #fff;
}
.tab {
  display: inline-block;
  padding: 8rpx 24rpx;
  margin: 0 8rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}
.tab.active {
  color: #fff;
  background: var(--color-primary);
}

.venue-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.venue-name { font-size: 32rpx; font-weight: 600; margin-bottom: 8rpx; }
.venue-tags { margin-bottom: 8rpx; }
.tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  margin-right: 8rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: var(--color-primary);
  background: #e8f5e9;
}
.venue-address { font-size: 24rpx; color: #999; }
.empty { text-align: center; padding: 100rpx 0; color: #999; }
