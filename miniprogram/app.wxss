page {
  --color-primary: #07c160;
  --color-bg: #f5f5f5;
  --color-text: #333333;
  --color-text-secondary: #999999;
  --color-border: #eeeeee;
  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: var(--color-text);
}

.container {
  padding: 20rpx;
}
