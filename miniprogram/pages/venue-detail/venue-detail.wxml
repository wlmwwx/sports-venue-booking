<view class="container" wx:if="{{venue}}">
  <view class="venue-info">
    <view class="name">{{venue.name}}</view>
    <view class="address">{{venue.address}}</view>
    <view class="phone">电话：{{venue.phone}}</view>
  </view>

  <!-- 场地号 -->
  <scroll-view scroll-x class="courts">
    <block wx:for="{{courts}}" wx:key="_id">
      <view class="court {{activeCourt === item._id ? 'active' : ''}}" data-id="{{item._id}}" bindtap="selectCourt">
        {{item.name}}
      </view>
    </block>
  </scroll-view>

  <!-- 日期选择 -->
  <picker mode="date" value="{{date}}" bindchange="onDateChange">
    <view class="date-picker">选择日期：{{date}}</view>
  </picker>

  <!-- 时段网格 -->
  <view class="slots">
    <block wx:for="{{slots}}" wx:key="_id">
      <view class="slot {{item.status === 'available' ? '' : 'disabled'}} {{selectedSlot && selectedSlot._id === item._id ? 'selected' : ''}}" data-idx="{{index}}" bindtap="selectSlot">
        <text>{{item.startTime}}-{{item.endTime}}</text>
        <text class="price">¥{{item.price}}</text>
      </view>
    </block>
    <view wx:if="{{slots.length === 0}}" class="empty">该日期暂无可用时段</view>
  </view>

  <button class="book-btn" disabled="{{!selectedSlot}}" bindtap="goBook">立即预定</button>
</view>
