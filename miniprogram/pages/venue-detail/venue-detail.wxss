.venue-info { background: #fff; padding: 24rpx; margin-bottom: 16rpx; border-radius: 12rpx; }
.name { font-size: 36rpx; font-weight: 600; margin-bottom: 8rpx; }
.address { font-size: 26rpx; color: #666; margin-bottom: 4rpx; }
.phone { font-size: 26rpx; color: #07c160; }
.courts { white-space: nowrap; padding: 16rpx 0; }
.court { display: inline-block; padding: 12rpx 28rpx; margin-right: 16rpx; border-radius: 8rpx; font-size: 26rpx; background: #f5f5f5; }
.court.active { background: var(--color-primary); color: #fff; }
.date-picker { background: #fff; padding: 20rpx; margin: 16rpx 0; border-radius: 12rpx; font-size: 28rpx; }
.slots { display: flex; flex-wrap: wrap; gap: 12rpx; }
.slot { width: 30%; padding: 16rpx; border-radius: 8rpx; background: #e8f5e9; text-align: center; font-size: 24rpx; }
.slot.disabled { background: #f5f5f5; color: #ccc; }
.slot.selected { background: var(--color-primary); color: #fff; }
.price { display: block; font-size: 28rpx; font-weight: 600; margin-top: 4rpx; }
.empty { width: 100%; text-align: center; color: #999; padding: 60rpx 0; }
.book-btn { position: fixed; bottom: 0; left: 0; right: 0; border-radius: 0; background: var(--color-primary); color: #fff; }
